{
	"name": "cka-learning-tracker",
	"version": "0.7.12",
	"private": true,
	"description": "Static CKA study tracker and practice task site.",
	"scripts": {
		"build": "node build.mjs",
		"format": "prettier --write \"**/*.{html,css,js,json,md,yml,yaml}\"",
		"format:check": "prettier --check \"**/*.{html,css,js,json,md,yml,yaml}\"",
		"lint": "npm run lint:js && npm run lint:css && npm run lint:html && npm run lint:md",
		"lint:js": "eslint build.mjs src/data/**/*.js src/js/**/*.js",
		"lint:css": "stylelint \"src/css/**/*.css\"",
		"lint:html": "htmlhint \"src/*.html\"",
		"lint:md": "markdownlint-cli2 \"**/*.md\" \"#node_modules\"",
		"cluster:up": "node cluster/cluster.mjs up",
		"cluster:down": "node cluster/cluster.mjs down",
		"cluster:reset": "node cluster/cluster.mjs reset",
		"cluster:status": "node cluster/cluster.mjs status"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"adm-zip": "^0.5.18",
		"esbuild": "^0.28.1",
		"eslint": "^10.6.0",
		"globals": "^17.6.0",
		"htmlhint": "^1.6.3",
		"markdownlint-cli2": "^0.23.1",
		"prettier": "^3.9.5",
		"react": "^19.2.5",
		"react-dom": "^19.2.7",
		"stylelint": "^17.14.0",
		"stylelint-config-standard": "^40.0.0"
	}
}
